    if antiSlipOn then
        local char = player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if root and hum then
                pcall(function()
                    root:SetNetworkOwner(player)
                end)

                local vel = root.AssemblyLinearVelocity  
                local move = hum.MoveDirection  

                if move.Magnitude > 0 then      
                    local dir = move.Unit      
                    local speed = hum.WalkSpeed      
                    root.AssemblyLinearVelocity = Vector3.new(dir.X * speed, vel.Y, dir.Z * speed)      
                else      
                    root.AssemblyLinearVelocity = Vector3.new(0, vel.Y, 0)      
                end      
            end      
        end  
    end
end))

local function setupAntiTrip(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if hum then
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)

        table.insert(connections, hum.StateChanged:Connect(function(_, new)  
            if new == Enum.HumanoidStateType.FallingDown or new == Enum.HumanoidStateType.Ragdoll then  
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)  
            end  
        end))  
    end
end

if player.Character then
