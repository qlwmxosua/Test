local function getEvents()
    local p = workspace:FindFirstChild(player.Name)
    if not p then return end
    local events = p:FindFirstChild("Events")
    if not events then return end
    return events
end

local function isValidBlock(obj)
    if not obj:IsA("BasePart") then return false end
    if obj.Anchored == false then return false end
    if obj.Parent:FindFirstChild("Humanoid") then return false end
    if obj.Position.Y < 0 then return false end
    return true
end

local cachedBlocks = {}

local function refreshBlocks()
    cachedBlocks = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if isValidBlock(v) then
            table.insert(cachedBlocks, v)
        end
    end
end

refreshBlocks()

task.spawn(function()
    while true do
        task.wait(5)
        refreshBlocks()
    end
end)

local function getRandomBlock()
    if #cachedBlocks == 0 then return nil end
    local index = math.random(1, #cachedBlocks)
    return cachedBlocks[index]
end

