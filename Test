    mapRemoved = not mapRemoved
    if mapRemoved then
        removeMapBtn.Text = "Remove Map : ON"
        for _,v in pairs(workspace:GetChildren()) do
            if not Players:GetPlayerFromCharacter(v)
            and v ~= workspace.Terrain
            and not v:IsA("Camera")
            and not v:FindFirstChild("Events") then
                v.Parent = mapStorage
            end
        end

        local floor = Instance.new("Part")  
        floor.Name = "RemovedMapFloor"  
        floor.Size = Vector3.new(100000,1,100000)  
        floor.Position = Vector3.new(0,-1,0)  
        floor.Anchored = true  
        floor.Color = Color3.fromRGB(5,5,25)  
        floor.Parent = workspace  
    else  
        removeMapBtn.Text = "Remove Map : OFF"  
        for _,v in pairs(mapStorage:GetChildren()) do  
            v.Parent = workspace  
        end  
        local floor = workspace:FindFirstChild("RemovedMapFloor")  
        if floor then  
            floor:Destroy()  
        end  
    end
end)

