local function runTPAttack(target)
    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")  
    if not root then return end  

    local humanoid = char:FindFirstChildOfClass("Humanoid")  
    if not humanoid then return end  

    local head = char:FindFirstChild("Head")  

    local targetChar = target.Character  
    if not targetChar then return end  

    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")  
    if not targetRoot then return end  

    local start = root.CFrame  
    local startTime = tick()  

    antiflingEnabled = true  
    isTeleporting = true

    local connection  
    connection = RunService.RenderStepped:Connect(function()  
        if not gui.Parent then  
            isTeleporting = false
            if connection then connection:Disconnect() end  
            return  
        end  
        if not targetRoot or not targetRoot.Parent then
            if safeZoneActive then
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
                root.CFrame = safeZoneTargetCF
            else
                root.CFrame = start  
            end
            antiflingEnabled = false  
            isTeleporting = false
            if connection then connection:Disconnect() end  
            return  
        end  
          
        if tick() - startTime < 1 then  
            local headOffset = head and (head.Position - root.Position) or Vector3.new(0, 1.5, 0)  
            local footY = targetRoot.Position.Y - (targetRoot.Size.Y/2)  
            local midY = (targetRoot.Position.Y + footY)/2  
            local tpPos = Vector3.new(targetRoot.Position.X, midY, targetRoot.Position.Z)  
            local look = targetRoot.CFrame.LookVector  
            root.CFrame = CFrame.new(tpPos - headOffset, (tpPos - headOffset) + look)  
        else
            if safeZoneActive then
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
                root.CFrame = safeZoneTargetCF
            else
                root.CFrame = start  
            end
            antiflingEnabled = false  
            isTeleporting = false
            connection:Disconnect()  
        end  
    end)  

    local events = getEvents()  
    if events then  
        local throw = events:FindFirstChild("Throw")  
        if throw then  
            throw:FireServer()  
            task.wait(0.05)  
            throw:FireServer()  
            task.wait(0.05)  
            throw:FireServer()  
        end  
    end
end

local function runTPGrab(target)
    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")  
    if not root then return end  

    local targetChar = target.Character  
    if not targetChar then return end  

    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")  
    if not targetRoot then return end  

    local start = root.CFrame  
    local startTime = tick()  
    local lastFire = 0  

    antiflingEnabled = true  
    isTeleporting = true

    local connection  
    connection = RunService.RenderStepped:Connect(function()  
        if not gui.Parent then  
            isTeleporting = false
            if connection then connection:Disconnect() end  
            return  
        end  
        if not targetRoot or not targetRoot.Parent then  
            if safeZoneActive then
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
                root.CFrame = safeZoneTargetCF
            else
                root.CFrame = start  
            end
            antiflingEnabled = false  
            isTeleporting = false
            if connection then connection:Disconnect() end  
            return  
        end  

        if tick() - startTime < 1 then  
            if tick() - lastFire > 0.1 then  
                lastFire = tick()  

                local pos = targetRoot.Position  
                local look = targetRoot.CFrame.LookVector  

                local targetFootY = targetRoot.Position.Y - (targetRoot.Size.Y / 2)  
                local finalY = targetFootY + (root.Size.Y / 2)  

                local finalPos = Vector3.new(pos.X, finalY, pos.Z)  

                root.CFrame = CFrame.new(finalPos - look * (root.Size.Y / 2), finalPos)  

                pcall(function()  
                    local events = getEvents()  
                    if events then  
                        local grab = events:FindFirstChild("Grab")  
                        if grab then  
                            grab:FireServer(false, true, pos, "弯腰抓取")  
                        end  
                    end  
                end)  
            end  
        else  
            if safeZoneActive then
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
                root.CFrame = safeZoneTargetCF
            else
                root.CFrame = start  
            end
            antiflingEnabled = false  
            isTeleporting = false
            connection:Disconnect()  
        end  
    end)
end

local function createPlayerButton(plr)
    if plr == player then return end

    local btn = Instance.new("TextButton")  
    btn.Parent = listFrame  
    btn.Size = UDim2.new(1,0,0,20)  
    btn.Text = plr.DisplayName  
    btn.BackgroundColor3 = Color3.fromRGB(60,60,60)  
    btn.MouseButton1Click:Connect(function()  
        runTPAttack(plr)  
    end)  

    local grabBtn = Instance.new("TextButton")  
    grabBtn.Parent = grabListFrame  
    grabBtn.Size = UDim2.new(1,0,0,20)  
    grabBtn.Text = plr.DisplayName  
    grabBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)  
    grabBtn.MouseButton1Click:Connect(function()  
        runTPGrab(plr)  
    end)
end

for _,plr in pairs(Players:GetPlayers()) do
    createPlayerButton(plr)
end

table.insert(connections, Players.PlayerAdded:Connect(createPlayerButton))

table.insert(connections, Players.PlayerRemoving:Connect(function(plr)
    for _,v in pairs(listFrame:GetChildren()) do
        if v:IsA("TextButton") and v.Text == plr.DisplayName then
            v:Destroy()
        end
    end
    for _,v in pairs(grabListFrame:GetChildren()) do
        if v:IsA("TextButton") and v.Text == plr.DisplayName then
            v:Destroy()
        end
    end
end))

