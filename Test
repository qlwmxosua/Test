local safeZoneLastPos = nil
local safeZoneConnectionsList = {}

local function hardLockSafeZone()
    if safeZoneActive and not isTeleporting then
        local char = player.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = safeZoneTargetCF
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
            end
        end
    end
end

local function stopSafeZoneLock()
    for _, connection in pairs(safeZoneConnectionsList) do
        connection:Disconnect()
    end
    safeZoneConnectionsList = {}
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
        end
    end
end

local function startSafeZoneLock()
    table.insert(safeZoneConnectionsList, RunService.RenderStepped:Connect(hardLockSafeZone))
    table.insert(safeZoneConnectionsList, RunService.Stepped:Connect(hardLockSafeZone))
    table.insert(safeZoneConnectionsList, RunService.Heartbeat:Connect(hardLockSafeZone))

    local char = player.Character  
    if char then  
        local hrp = char:FindFirstChild("HumanoidRootPart")  
        local hum = char:FindFirstChildOfClass("Humanoid")  
        if hrp then  
            table.insert(safeZoneConnectionsList, hrp:GetPropertyChangedSignal("CFrame"):Connect(hardLockSafeZone))  
            table.insert(safeZoneConnectionsList, hrp:GetPropertyChangedSignal("Position"):Connect(hardLockSafeZone))  
        end  
        if hum then  
            hum.PlatformStand = true  
        end  
    end
end

